generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Trip {
  id                Int        @id @default(autoincrement())

  departureSite     String
  arrivalSite       String

  availableFromTime String
  latestDeliveryTime String?

  availableFromDate   DateTime?
  latestDeliveryDate  DateTime?

  vehicleType       String
  vehiclePlate      String

  driverName        String?

  comment           String?

  status            TripStatus @default(PENDING)

  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  amountHt   Float?
  invoiceId  Int?
  invoice    Invoice? @relation(fields: [invoiceId], references: [id])
}

enum TripStatus {
  PENDING
  EN_ROUTE
  DELIVERED
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  role      UserRole @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum UserRole {
  ADMIN
  USER
}

model Invoice {
  id         Int           @id @default(autoincrement())
  reference  String        @unique
  startDate  DateTime
  endDate    DateTime
  status     InvoiceStatus @default(PENDING)

  totalHt    Float         @default(0)
  taxAmount  Float         @default(0)
  totalTtc   Float         @default(0)

  trips      Trip[]

  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
}

enum InvoiceStatus {
  PENDING
  PAID
}

model PricingRoute {
  id            Int      @id @default(autoincrement())
  departureSite String
  arrivalSite   String
  amountHt      Float

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([departureSite, arrivalSite])
}